# Database connection string (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/salesman_tracker

# JWT signing secret — must be at least 16 characters
JWT_SECRET=change-me-to-a-long-random-string

# Environment: 'production' enables SSL for DB connections
NODE_ENV=development

# Server port
PORT=3000

# CORS: comma-separated list of allowed origins (leave empty to allow all in dev)
CORS_ORIGIN=
